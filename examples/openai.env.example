# Copy to .env, adjust the values, and keep .env out of Git.
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-5.6-luna
# Optional custom OpenAI-compatible endpoint. Omit for the official API.
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=256
OPENAI_TIMEOUT=120
PYVEIL_SECRET=replace-with-a-long-random-hmac-secret
PYVEIL_SCOPE=tenant-123/openai
