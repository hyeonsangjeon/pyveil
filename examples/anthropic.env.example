# Copy to .env, adjust the values, and keep .env out of Git.
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
ANTHROPIC_MODEL=claude-haiku-4-5
# Optional custom endpoint. Omit for the official Claude API.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MAX_TOKENS=256
ANTHROPIC_TIMEOUT=120
PYVEIL_SECRET=replace-with-a-long-random-hmac-secret
PYVEIL_SCOPE=tenant-123/anthropic
