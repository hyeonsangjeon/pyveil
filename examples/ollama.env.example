# Copy to .env, adjust the values, and keep .env out of Git.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=128
OLLAMA_TEMPERATURE=0.2
# Use 5m for faster repeated calls; 0 releases memory after each response.
OLLAMA_KEEP_ALIVE=0
OLLAMA_TIMEOUT=120
PYVEIL_SECRET=replace-with-a-long-random-hmac-secret
PYVEIL_SCOPE=tenant-123/local-ollama
